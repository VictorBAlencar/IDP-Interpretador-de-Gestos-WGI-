{
  "manifest_version": 3,
  "name": "WGC - Web Gesture Controller",
  "version": "1.0",
  "description": "Controle o cursor do mouse usando gestos da mão capturados pela webcam.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WGC Mouse"
  },
  "icons": {
  }
}